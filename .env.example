# Required: encrypts admin-connected Sumble keys at rest. Any random string
# (hashed to a 32-byte AES-256-GCM key). Generate e.g. `openssl rand -hex 32`.
ENCRYPTION_KEY=

# HubSpot Service Key with scopes:
#   crm.objects.companies.read  (read company props)
#   crm.lists.read              (read HubSpot lists for the List Builder app page)
# Create at: HubSpot Settings -> Integrations -> Service Keys
HUBSPOT_SERVICE_KEY=

# Render Postgres connection string (set automatically on Render; for local use a local pg)
DATABASE_URL=

# Optional single-tenant guard: only this HubSpot portal id may connect/use Sumble.
# Leave unset for multi-tenant (then verify HubSpot request signatures instead).
ALLOWED_PORTAL_ID=

# Optional fallback Sumble API key. Admins normally connect Sumble via the app's
# Settings page (stored encrypted, per portal); this is only a backstop.
SUMBLE_API_KEY=
