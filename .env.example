# Sumble API key (Bearer). Create at sumble.com/account/api-keys
SUMBLE_API_KEY=

# HubSpot Service Key with scope crm.objects.companies.read
# Create at: HubSpot Settings -> Integrations -> Service Keys
HUBSPOT_SERVICE_KEY=

# Render Postgres connection string (set automatically on Render; for local use a local pg)
DATABASE_URL=
